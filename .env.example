# HermesClaw Complete Environment Configuration
# Copy to .env and fill in your actual values

# ============================================================
# LLM PROVIDERS (Choose one or use multiple)
# ============================================================

# Ollama (Local - Recommended for development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# OpenAI
OPENAI_API_KEY=sk-...your-openai-key...

# Groq (Fast inference)
GROQ_API_KEY=gsk_...your-groq-key...

# DeepSeek
DEEPSEEK_API_KEY=sk-...your-deepseek-key...

# XAI (X.com/Grok)
XAI_API_KEY=...your-xai-key...

# Together AI
TOGETHER_API_KEY=...your-together-key...

# Fireworks AI
FIREWORKS_API_KEY=...your-fireworks-key...

# ============================================================
# BOT PLATFORMS (Optional - only if using specific platforms)
# ============================================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGhijklmnopqrstuvwxyz...

# Discord Bot
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# WhatsApp (via pywhatkit - use at own risk)
WHATSAPP_API_KEY=your_whatsapp_key_here

# Allowed Users (comma-separated user IDs for Telegram/Discord)
ALLOWED_USERS=123456789,987654321

# ============================================================
# DASHBOARD & API (Frontend & Backend Configuration)
# ============================================================

# Frontend URLs (for React Dashboard - used in vite.config.ts)
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001/ws/dashboard

# Backend Server Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true

# CORS Configuration (for dashboard access)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# MEMORY & KNOWLEDGE BASE
# ============================================================

SQLITE_DB_PATH=hermes/memory.db
CHROMA_DB_PATH=hermes/chroma_db
CHROMA_COLLECTION=hermes_knowledge
MAX_CONTEXT_TOKENS=12000

# ============================================================
# KAIROS DAEMON (Proactive Problem Detection)
# ============================================================

KAIROS_ENABLED=true
KAIROS_SCAN_INTERVAL_MINUTES=15
KAIROS_MAX_PROACTIVE_FIXES=3
KAIROS_REQUIRE_APPROVAL=true
KAIROS_SCAN_PATHS=.,core,hermes,agents

# ============================================================
# SWARM CONFIGURATION
# ============================================================

MAX_CONCURRENT_AGENTS=4
DEFAULT_TIMEOUT_PER_TASK=600

# ============================================================
# SAFETY & APPROVALS
# ============================================================

AUTO_APPROVE_SAFE_OPERATIONS=true
APPROVAL_TIMEOUT_SECONDS=300

# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=INFO
LOG_FORMAT=detailed
LOG_FILE=logs/hermes.log

# ============================================================
# DEVELOPMENT FLAGS
# ============================================================

DEBUG_MODE=false
VERBOSE_OUTPUT=false
DEVELOPMENT_ENV=true
